{"html":{"reading.html":"\n<html lang=\"en\">\n    <head>\n        <meta charset=\"UTF-8\" /><meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\" /> \n    <h1 class=\"title\"> Bhagavad Gita - Reading View </h1>\n        <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,100..900;1,100..900&display=swap\" rel=\"stylesheet\" /><link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@100..900&display=swap\" /><style>\n            body { font-family: 'Noto Serif', serif; max-width: 1200px; margin: 0 auto; padding: 20px; background: #fdfdfd; color: #333; }\n            h1 { text-align: center; color: #d35400; border-bottom: 2px solid #eee; padding-bottom: 1rem; }\n            .verse-container { border-bottom: 1px solid #eee; padding: 40px 0; }\n            .verse-header { margin-bottom: 20px; }\n            .verse-id { font-size: 1.2rem; font-weight: bold; color: #7f8c8d; }\n            \n            .verse-grid { \n                display: grid; \n                grid-template-columns: 1fr 1fr 1fr; \n                gap: 40px; \n            }\n            \n            @media (max-width: 900px) {\n                .verse-grid { grid-template-columns: 1fr; gap: 20px; }\n            }\n\n            .column-header { \n                font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; \n                color: #999; margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px;\n            }\n\n            .mula { font-family: 'Noto Sans Devanagari', sans-serif; font-size: 1.2rem; line-height: 1.8; }\n            .transliteration { font-style: italic; color: #555; }\n            .translation { line-height: 1.6; }\n            \n            /* Hide internals if leaked */\n            .entity-header, .uvacha-label { display: inline-block; font-weight: bold; margin-right: 5px; }\n            .entity-header::after { content: \" \"; }</style></head>\n    <div class=\"reading-body\">\n        <h1> Bhagavad Gita As It Is </h1>\n        \n        <div class=\"verse-list\">\n            \n                <div class=\"verse-container\" id=\"$.id\">\n                     <div class=\"verse-header\">\n                        <div class=\"verse-id\"> Verse $.id </div></div>\n                     <div class=\"verse-grid\">\n                         <div class=\"column mula-col\">\n                             <div class=\"column-header\"> Sanskrit </div>\n                             <div class=\"mula\"> $.mula.body </div></div>\n                         <div class=\"column iast-col\">\n                             <div class=\"column-header\"> Transliteration </div>\n                             <div class=\"transliteration\"> $.iast.body </div></div>\n                         <div class=\"column en-col\">\n                             <div class=\"column-header\"> Translation </div>\n                             <div class=\"translation\"> $.en.body </div></div></div></div></div></div></html>\n","reference.html":"<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bhagavad Gita — Reference</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,100..900;1,100..900&display=swap\"\n        rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Noto Serif', serif;\n            max-width: 700px;\n            margin: 0 auto;\n            padding: 2rem;\n            line-height: 1.8;\n            color: #2c3e50;\n            background-color: #fefefe;\n        }\n\n        .verse-box {\n            margin-bottom: 2rem;\n            padding: 1rem 1.5rem;\n            border-left: 3px solid #d35400;\n            background: #fdf8f4;\n        }\n\n        .verse-ref {\n            display: block;\n            font-size: 0.75rem;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            color: #d35400;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n        }\n\n        .devanagari {\n            font-family: 'Noto Sans Devanagari', sans-serif;\n            font-size: 1.3rem;\n            margin-bottom: 0.75rem;\n            font-weight: 500;\n            line-height: 1.6;\n        }\n\n        .iast {\n            font-style: italic;\n            color: #555;\n            font-size: 1.05rem;\n            line-height: 1.5;\n        }\n\n        .entity-name {\n            font-weight: 700;\n            color: #2c3e50;\n            font-size: 0.9rem;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* Collection View Styles */\n        .chapter-entry {\n            margin-bottom: 2rem;\n            padding-bottom: 1rem;\n            border-bottom: 1px solid #eee;\n        }\n\n        .chapter-entry h2 {\n            font-size: 1.2rem;\n            margin-bottom: 0.5rem;\n            color: #7f8c8d;\n        }\n\n        .chapter-entry p {\n            display: flex;\n            align-items: baseline;\n            gap: 1rem;\n            margin: 0;\n        }\n\n        .speaker {\n            font-family: 'Noto Sans Devanagari', sans-serif;\n            font-weight: 600;\n            color: #d35400;\n            min-width: 120px;\n        }\n\n        h1 {\n            border-bottom: 2px solid #d35400;\n            padding-bottom: 0.5rem;\n            color: #2c3e50;\n        }\n\n        a {\n            color: #2980b9;\n            text-decoration: none;\n            font-weight: 500;\n        }\n\n        a:hover {\n            text-decoration: underline;\n        }\n    </style>\n</head>\n\n<body>\n    // Reference: verses only\n<h1> All Verses </h1>\n\n    <div class=\"verse-box\" id=\"urn:vedabase:bg:1.1\">\n        <div class=\"verse-ref\"> Verse urn:vedabase:bg:1.1 </div>\n        <div class=\"verse-text\">\n                <div class=\"devanagari\"> <div class=\"entity-header\"> धृतराष्ट्र </div><div class=\"uvacha-label\"> उवाच </div><div class=\"verse-box\"><div class=\"verse-ref\"> Verse 1 </div><div class=\"devanagari\">\n        धर्मक्षेत्रे कुरुक्षेत्रे समवेता युयुत्सव:<br /> \n        मामका: पाण्डवाश्चैव किमकुर्वत सञ्जय\n        </div></div> </div>\n                <div class=\"iast\"> <div class=\"entity-header\"> dhṛtarāṣṭra </div><div class=\"uvacha-label\"> uvāca </div><div class=\"verse-box\"><div class=\"verse-ref\"> Verse 1 </div><div class=\"iast\">\n        dharma-kṣetre kuru-kṣetre\n        samavetā yuyutsavaḥ <br />\n        māmakāḥ pāṇḍavāś caiva\n        kim akurvata sañjaya\n        </div></div> </div></div>\n        <p>\n            <a href=\"urn:vedabase:bg:1.1?view=reading\"> Read Full Verse </a></p></div>\n    <div class=\"verse-box\" id=\"urn:vyasa:bg:18:78\">\n        <div class=\"verse-ref\"> Verse urn:vyasa:bg:18:78 </div>\n        <div class=\"verse-text\">\n                <div class=\"devanagari\">     <div class=\"verse-box\"><div class=\"verse-ref\"> Verse 78 </div><div class=\"devanagari\">\n    यत्र योगेश्वरः कृष्णो यत्र पार्थो धनुर्धरः ।\n    तत्र श्रीर्विजयो भूतिर्ध्रुवा नीतिर्मतिर्मम ॥ ७८ ॥\n    </div></div> </div>\n                <div class=\"iast\"> <div class=\"verse-box\"><div class=\"verse-ref\"> Verse 78 </div><div class=\"iast\">\n    yatra yogeśvaraḥ kṛṣṇo\n    yatra pārtho dhanur-dharaḥ\n    tatra śrīr vijayo bhūtir\n    dhruvā nītir matir mama\n    </div></div> </div></div>\n        <p>\n            <a href=\"urn:vyasa:bg:18:78?view=reading\"> Read Full Verse </a></p></div>\n\n\n</body>\n\n</html>"},"urns":["urn:vyasa:bg:18:78"]}