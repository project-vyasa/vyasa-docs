---
import VyasaViewer from '../../components/VyasaViewer.svelte';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vyasa Viewer Demo</title>
    <style is:global>
      :root {
        --bg-surface: #ffffff;
        --text-primary: #111111;
        --font-sans: system-ui, -apple-system, sans-serif;
      }
      
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        background: var(--bg-surface);
        color: var(--text-primary);
        font-family: var(--font-sans);
        height: 100vh;
        overflow: hidden;
      }
      
      .viewer-wrapper {
        height: 100vh;
        width: 100vw;
      }
    </style>
  </head>
  <body>
    <div class="viewer-wrapper">
      <VyasaViewer client:only="svelte" catalogs={[`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}samples/catalog.json`]} />
    </div>
  </body>
</html>
